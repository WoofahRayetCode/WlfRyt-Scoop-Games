{
    "version": "16bff1183",
    "description": "Nintendo Switch emulator (nightly build)",
    "homepage": "https://github.com/citron-neo/emulator",
    "license": {
        "identifier": "GPL-3.0-or-later",
        "url": "https://github.com/citron-neo/emulator/blob/main/LICENSE.txt"
    },
    "notes": "ATTENTION: Citron requires Nintendo Switch firmware and a prod.keys file to function.",
    "suggest": {
        "Switch Army Knife (SAK)": "games/sak"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/citron-neo/CI/releases/download/nightly-windows/Citron-windows-nightly-16bff1183-x64-clangtron.zip",
            "hash": "1375df86ad3c0adb4621cc95bfe8f9d87406fe6d31054907ebe8b25a173f28cf"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "   New-item \"$persist_dir\" -ItemType Directory | Out-Null",
        "   New-item \"$persist_dir\\user\" -ItemType Directory | Out-Null",
        "   if (Test-Path \"$env:APPDATA\\citron\") {",
        "       Write-host \"Migrating AppData...\" -ForegroundColor yellow",
        "       Copy-Item -Path \"$env:APPDATA\\citron\\*\" -Destination \"$persist_dir\\user\" -Recurse",
        "       Remove-Item -Path \"$env:APPDATA\\citron\" -Recurse",
        "   }",
        "}"
    ],
    "bin": "citron.exe",
    "shortcuts": [
        [
            "citron.exe",
            "Citron"
        ]
    ],
    "persist": "user",
    "checkver": {
        "url": "https://api.github.com/repos/citron-neo/CI/releases/tags/nightly-windows",
        "jsonpath": "$.assets[0].name",
        "regex": "Citron-windows-nightly-([\\w]+)-x64-clangtron\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/citron-neo/CI/releases/download/nightly-windows/Citron-windows-nightly-$version-x64-clangtron.zip"
            }
        }
    }
}
