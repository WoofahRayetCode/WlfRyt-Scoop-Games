        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "   New-item \"$persist_dir\" -ItemType Directory | Out-Null",
        "   New-item \"$persist_dir\\user\" -ItemType Directory | Out-Null",
        "   if (Test-Path \"$env:APPDATA\\citron\") {",
        "       Write-host \"Migrating AppData...\" -ForegroundColor yellow",
        "       Copy-Item -Path \"$env:APPDATA\\citron\\*\" -Destination \"$persist_dir\\user\" -Recurse",
        "       Remove-Item -Path \"$env:APPDATA\\citron\" -Recurse",
        "   }",
        "}"
    ],
    "bin": "citron.exe",
    "shortcuts": [
        [
            "citron.exe",
            "Citron"
        ]
    ],
    "persist": "user",
    "checkver": {
        "url": "https://api.github.com/repos/citron-neo/CI/releases/tags/nightly-windows",
        "jsonpath": "$.assets[0].name",
        "regex": "Citron-windows-nightly-([\\w]+)-x64-clangtron\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/citron-neo/CI/releases/download/nightly-windows/Citron-windows-nightly-$version-x64-clangtron.zip"
            }
        }
    }
}
