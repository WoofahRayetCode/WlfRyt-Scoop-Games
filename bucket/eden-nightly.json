    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "   New-item \"$persist_dir\" -ItemType Directory | Out-Null",
        "   New-item \"$persist_dir\\user\" -ItemType Directory | Out-Null",
        "   if (Test-Path \"$env:APPDATA\\eden\") {",
        "       Write-host \"Migrating AppData...\" -ForegroundColor yellow",
        "       Copy-Item -Path \"$env:APPDATA\\eden\\*\" -Destination \"$persist_dir\\user\" -Recurse",
        "       Remove-Item -Path \"$env:APPDATA\\eden\" -Recurse",
        "   }",
        "}"
    ],
    "bin": "eden.exe",
    "shortcuts": [
        [
            "eden.exe",
            "Eden (Nightly)"
        ]
    ],
    "persist": "user",
    "checkver": {
        "url": "https://git.eden-emu.dev/eden-ci/nightly/releases",
        "regex": "tag/v(([\\d.]+)\\.(?<hash>[\\w\\d]+))"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://git.eden-emu.dev/eden-ci/nightly/releases/download/v$version/Eden-Windows-$matchHash-amd64-msvc-standard.zip"
            },
            "arm64": {
                "url": "https://git.eden-emu.dev/eden-ci/nightly/releases/download/v$version/Eden-Windows-$matchHash-arm64-clang-standard.zip"
            }
        }
    }
