{
    "version": "2026.06.07-10a173b5536fc75cd93f8a3868349dad963542ef",
    "description": "A Nintendo DS emulator aiming for fast and accurate emulation (Nightly builds)",
    "homepage": "http://melonds.kuribo64.net/",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://nightly.link/melonDS-emu/melonDS/workflows/build-windows/master/melonDS-windows-x86_64.zip",
            "hash": "d26318c7ec1eb68ff67138ca6fa507831f62bfd8b83b1f2a8fec55afa5f3abe0"
        }
    },
    "installer": {
        "script": [
            "if (Test-Path \"$persist_dir\\melonDS.toml\" -PathType Container) {",
            "    Remove-Item \"$persist_dir\\melonDS.toml\" -Recurse -Force",
            "}",
            "$FILES = @('melonDS.ini', 'melonDS.toml')",
            "foreach ($FILE in $FILES) {",
            "    if (!(Test-Path \"$persist_dir\\$FILE\")) {",
            "        if (Test-Path \"$dir\\$FILE\") {",
            "             Copy-Item \"$dir\\$FILE\" \"$persist_dir\\$FILE\"",
            "        } else {",
            "             New-Item \"$dir\\$FILE\" -Type File | Out-Null",
            "        }",
            "    }",
            "}"
        ]
    },
    "bin": "melonDS.exe",
    "shortcuts": [
        [
            "melonDS.exe",
            "melonDS (Nightly)"
        ]
    ],
    "persist": [
        "melonDS.ini",
        "melonDS.toml"
    ],
    "checkver": {
        "url": "https://github.com/melonDS-emu/melonDS/commits/master.atom",
        "regex": "(?s)<entry>.*?<id>.*?/([a-f0-9]+)</id>.*?<updated>(?<year>\\d+)-(?<month>\\d+)-(?<day>\\d+)T(?<hour>\\d+):(?<minute>\\d+):(?<second>\\d+)Z</updated>",
        "replace": "${year}.${month}.${day}-${1}"
    },
    "autoupdate": {
        "url": "https://nightly.link/melonDS-emu/melonDS/workflows/build-windows/master/melonDS-windows-x86_64.zip"
    }
}
